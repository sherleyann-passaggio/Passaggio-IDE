# ═══════════════════════════════════════════════════════════════════════════
# PASSAGGIO AUTOMATION — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For cloud deployment (Render), set these via the dashboard's
# environment variable editor instead of a .env file.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Mode ─────────────────────────────────────────────────────────────────
# ENVIRONMENT=local   → Enables the chokidar file watcher on GOOGLE_DRIVE_SYNC_PATH
#                       (use when running on your Mac with Google Drive synced locally)
# ENVIRONMENT=cloud   → Disables file watcher; relies on Telegram .md document
#                       ingestion + pasted markdown content for script processing.
#                       This is the default when not set.
ENVIRONMENT=cloud

# ─── Core Bot Secrets ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=7916710756

# ─── Model Switching (Cline / Continue) ───────────────────────────────────
# Path to the Cline/Continue VS Code extension config on the host machine.
# In cloud mode, model switching may not apply unless Cline is reachable.
CLINE_CONFIG_PATH=/Users/sherleybelleus/.continue/config.json
CLINE_DEFAULT_MODEL=claude-3-5-sonnet-20241022
CLINE_CHEAP_MODEL=claude-3-haiku-20240307

# ─── Local Paths ──────────────────────────────────────────────────────────
REMOTION_DIR=../remotion
BLUEPRINT_PATH=../remotion/props.json
MEDIA_DIR=./public/images

# ─── Render: AWS Lambda (Remotion Serverless) ─────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=passaggio-remotion-renders
REMOTION_FUNCTION_NAME=passaggio-remotion-renderer

# ─── Integrations: NVIDIA AI ──────────────────────────────────────────────
# NVIDIA OpenAI-compatible API endpoint for model-switching workflows.
# Used when you need NVIDIA-specific models (e.g., Nemotron, Llama on NIM).
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your_nvidia_api_key_here

# ─── Integrations: OpenRouter ─────────────────────────────────────────────
# OpenRouter API key used by Headroom/LiteLLM backend for multi-model routing.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Integrations: Headroom / LiteLLM ─────────────────────────────────────
# Base URL for the Headroom context-compression proxy.
HEADROOM_BASE_URL=http://127.0.0.1:8080

# ─── Google Drive (Cloud Mode — Optional) ─────────────────────────────────
# For secure, lightweight Google Drive API polling without local folder sync.
# Provide a Google Service Account credentials JSON (base64-encoded) that has
# read access to your target Drive folder. The poller will periodically check
# for new .md scripts and process them through the same pipeline.
#
# To generate: https://console.cloud.google.com/apis/credentials/serviceaccountkey
# Encode: cat credentials.json | base64 | pbcopy
GOOGLE_CREDENTIALS_JSON=""
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ─── Google Drive Sync (Local Mode) ───────────────────────────────────────
# Path to the locally synced Google Drive folder (macOS only).
# Only used when ENVIRONMENT=local.
GOOGLE_DRIVE_SYNC_PATH=/Users/sherleybelleus/Library/Mobile Documents/com~apple~CloudDocs/Passaggio IDE/
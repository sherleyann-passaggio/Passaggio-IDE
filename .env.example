# Passaggio IDE — Marketing Video Pipeline Environment Template
# Copy this file to .env and fill in your actual keys. NEVER commit .env to Git.

# ── Local Voice Engine (replaces ElevenLabs) ──
# Path to the voice-changer workspace
VOICE_CHANGER_DIR=/Users/sherleybelleus/Library/Mobile Documents/com~apple~CloudDocs/The Passaggio Tech Stack/voice-changer

# ── Optional: Remotion Cloud Rendering ──
REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_SECRET_ACCESS_KEY=

# ── Google Cloud / Vertex AI ──
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Firebase (for app prototypes) ──
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# ── Intake Pipeline Security ──
VAPI_WEBHOOK_SECRET=        # Bearer token used by /api/intake to verify calls from Vapi.ai
INTAKE_API_KEY=             # Used by /intake/process and the public portal form

# ── Vercel Blob (secure client-side file uploads) ──
BLOB_READ_WRITE_TOKEN=      # Vercel Blob read/write token for client uploads

# ── Telegram Alerts (serverless intake → your DM) ──
TELEGRAM_TOKEN=             # Bot token from @BotFather (used by api/intake.js)
CHAT_ID=                    # Your personal Telegram chat ID (from @userinfobot)

# ── Stripe (monetized intake funnel) ──
STRIPE_SECRET_KEY=          # sk_test_... or sk_live_... (used by api/intake.js)
STRIPE_WEBHOOK_SECRET=      # whsec_... for verifying Stripe webhook signatures
STRIPE_PUBLISHABLE_KEY=     # pk_test_... or pk_live_... (used by client-side redirects if needed)
STRIPE_PRICE_FOUNDER=       # price_... for the $50 Founding application fee
STRIPE_PRICE_STANDARD=      # price_... for the $50 standard-tier start fee

# ── Google reCAPTCHA v2 (secure the public intake form) ──
RECAPTCHA_SITE_KEY=         # 6Ld... for the HTML widget
RECAPTCHA_SECRET_KEY=        # 6Ld... for server-side verification

# ── Other Integrations ──
VITE_COHERE_API_KEY=
VITE_COMMAND_A_API_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
